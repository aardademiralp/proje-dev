# ISU-SecOps-Orchestrator Ortam Değişkenleri Örneği
# ==================================================
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Uygulama Genel Ayarları
# ---------------------------------------------------------------------------
ISU_APP_NAME=ISU-SecOps-Orchestrator
ISU_APP_VERSION=1.0.0
ISU_APP_HOST=0.0.0.0
ISU_APP_PORT=8000
ISU_DEBUG=false

# ---------------------------------------------------------------------------
# Loglama
# ---------------------------------------------------------------------------
# Seviyeler: DEBUG, INFO, WARNING, ERROR, CRITICAL
ISU_LOG_LEVEL=INFO
# Formatlar: json (üretim), text (geliştirme)
ISU_LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Rust Engine Ayarları
# ---------------------------------------------------------------------------
# Rust binary'sinin tam dosya yolu
ISU_ENGINE_PATH=./core_engine/isu-secops-engine
# Tarama zaman aşımı (saniye, min: 10, max: 600)
ISU_SCAN_TIMEOUT=120
# Eş zamanlı maksimum tarama sayısı
ISU_MAX_CONCURRENT_SCANS=5

# ---------------------------------------------------------------------------
# Raporlama Ayarları
# ---------------------------------------------------------------------------
ISU_REPORTS_DIR=./reports
ISU_REPORT_INCLUDE_REMEDIATION=true
ISU_REPORT_INCLUDE_CVSS=true
ISU_REPORT_ORGANIZATION=ISU Cyber Security Research Lab

# ---------------------------------------------------------------------------
# Güvenlik Ayarları
# ---------------------------------------------------------------------------
# CORS için izin verilen origin'ler (JSON liste formatı)
# ISU_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
